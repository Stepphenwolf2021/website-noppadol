<!DOCTYPE html>
<html lang="{{ lang or 'th' }}">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{% if title %}{{ title }} — {% endif %}{{ site.wordmark }}</title>
<meta name="description" content="{{ subtitle or site.tagline }}">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,800;1,400;1,600&family=Trirong:ital,wght@0,500;0,600;0,700;0,800;1,500;1,600;1,700&family=IBM+Plex+Sans+Thai:wght@300;400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">

<link rel="stylesheet" href="/assets/css/seize.css">

{# ---- palette ประจำฉบับ (โทน navy) — เปลี่ยนได้จาก <ฉบับ>.11tydata.json ---- #}
<style>
:root{
  --cover-green:{{ palette.cover_green or '#2D3952' }};
  --cover-green-deep:{{ palette.cover_green_deep or '#273145' }};
  --cover-green-light:{{ palette.cover_green_light or '#394E6E' }};
  --issue-green:{{ palette.issue_green or '#354E6F' }};
  --issue-orange:{{ palette.issue_orange or '#5E7DAF' }};
  --issue-red:{{ palette.issue_red or '#8C5A7A' }};
}
</style>

{# ---- schema.org JSON-LD (ชั้น ontology) ---- #}
{% include "partials/jsonld.njk" %}
</head>
<body>

<nav class="utility" aria-label="แถบเครื่องมือ">
  <button class="back-btn" onclick="history.length>1?history.back():window.location.href='/'">
    <span class="arrow" aria-hidden="true">←</span> หน้าแรก
  </button>
  <span class="mini-mast">noppadol<span class="middot">·</span>online</span>
  <span class="issue-code">{{ issue_code or '' }}</span>
</nav>

{{ content | safe }}

</body>
</html>
