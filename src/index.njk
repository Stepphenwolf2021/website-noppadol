---
permalink: /index.html
eleventyExcludeFromCollections: true
---
{% set items = collections.issues[0].items %}
{% set lead = items | coverOf %}
{% set d = lead.data %}
{% set pal = d.palette %}
{% set cv = d.cover %}
<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ site.name }} — {{ site.tagline }}</title>
<meta name="description" content="{{ site.tagline }} · ฉบับที่ {{ d.issue }} {{ d.issue_label }}">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,800;1,400;1,600&family=Trirong:ital,wght@0,500;0,600;0,700;1,500;1,600&family=IBM+Plex+Sans+Thai:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/assets/css/seize.css">

<style>
:root{
  --cover-green:{{ pal.cover_green }};
  --cover-green-deep:{{ pal.cover_green_deep }};
  --cover-green-light:{{ pal.cover_green_light }};
  --issue-green:{{ pal.issue_green }};
  --issue-orange:{{ pal.issue_orange }};
  --issue-red:{{ pal.issue_red }};
}

/* ===================== COVER STAGE (เต็มจอ + พลิก) ===================== */
.cover-stage{
  position:fixed;inset:0;z-index:100;
  perspective:2000px;
  background:transparent;   /* โปร่งใส — สารบัญด้านหลังเผยออกเมื่อปกพลิก */
}
.cover{
  position:absolute;inset:0;
  transform-origin:left center;
  transform:rotateY(0deg);
  transition:transform 1.15s cubic-bezier(.7,0,.2,1);
  backface-visibility:hidden;
  cursor:pointer;
  overflow:hidden;
  background:
    radial-gradient(120% 80% at 18% 22%, var(--cover-green-light) 0%, var(--cover-green) 46%, var(--cover-green-deep) 100%);
  box-shadow:inset 0 0 180px rgba(0,0,0,.28);
}
body.opened .cover{transform:rotateY(-118deg)}
body.opened .cover-stage{pointer-events:none}

/* ภาพปก full-bleed ขวา feather ซ้าย/บนเข้าพื้นเขียว */
.cover-art{
  position:absolute;top:0;right:0;bottom:0;width:66%;height:100%;
  object-fit:cover;object-position:50% 32%;
  -webkit-mask-image:linear-gradient(to right,transparent 0,#000 30%),linear-gradient(to bottom,transparent 0,#000 15%);
  -webkit-mask-composite:source-in;
  mask-image:linear-gradient(to right,transparent 0,#000 30%),linear-gradient(to bottom,transparent 0,#000 15%);
  mask-composite:intersect;
}
/* แถบส้ม–แดงขอบคมด้านล่าง */
.cover-band{
  position:absolute;left:0;right:0;bottom:0;height:11.5%;z-index:2;
  background:linear-gradient(to right,var(--issue-orange) 0 60%,var(--issue-red) 60% 100%);
}

.cover-inner{
  position:relative;z-index:3;height:100%;
  display:flex;flex-direction:column;justify-content:space-between;
  padding:clamp(28px,5vw,64px);
  color:var(--paper);
}
.cover-mast{
  font-family:var(--display);font-weight:700;
  font-size:clamp(2.6rem,6.4vw,5.2rem);line-height:1;letter-spacing:.005em;
  text-shadow:0 2px 30px rgba(0,0,0,.25);
}
.cover-mast .the{font-style:italic;color:var(--issue-orange);font-size:.56em;vertical-align:.22em;margin:0 .06em}
.cover-issueline{
  margin-top:calc(var(--grid)*1.5);font-family:var(--body);font-weight:400;
  font-size:13px;letter-spacing:.28em;text-transform:uppercase;color:rgba(250,247,241,.82);
}

.cover-mid{max-width:min(52%,30rem)}
.cover-eyebrow{
  font-family:var(--body);font-weight:600;font-size:12px;letter-spacing:.2em;
  text-transform:uppercase;color:var(--issue-orange);margin-bottom:calc(var(--grid)*1.5);
}
.cover-headline{
  font-family:var(--display-th);font-weight:700;
  font-size:clamp(1.6rem,3.4vw,2.7rem);line-height:1.18;margin:0;
  text-shadow:0 2px 24px rgba(0,0,0,.35);
}
.cover-blurb{
  margin-top:calc(var(--grid)*2);font-family:var(--body);font-weight:300;
  font-size:clamp(.95rem,1.5vw,1.1rem);line-height:1.6;color:rgba(250,247,241,.9);
}

.cover-foot{display:flex;align-items:flex-end;justify-content:space-between;gap:var(--grid)}
.cover-barcode{display:flex;flex-direction:column;gap:6px}
.barcode{
  width:158px;height:40px;
  background:repeating-linear-gradient(90deg,var(--paper) 0 2px,transparent 2px 4px,var(--paper) 4px 7px,transparent 7px 9px,var(--paper) 9px 11px,transparent 11px 15px);
  opacity:.92;
}
.cover-code{font-family:var(--body);font-weight:400;font-size:11px;letter-spacing:.22em;color:rgba(250,247,241,.8)}
.cover-open{
  display:inline-flex;align-items:center;gap:10px;
  font-family:var(--body);font-weight:500;font-size:13px;letter-spacing:.04em;
  color:var(--paper);
  background:rgba(250,247,241,.12);border:1px solid rgba(250,247,241,.4);
  padding:10px 18px;border-radius:999px;backdrop-filter:blur(4px);
  white-space:nowrap;
}
.cover-open .arw{animation:nudge 1.5s ease-in-out infinite}
@keyframes nudge{0%,100%{transform:translateX(0)}50%{transform:translateX(4px)}}

/* ===================== ใต้ปก: สารบัญฉบับ ===================== */
.issue-topbar{
  position:sticky;top:0;z-index:5;display:flex;align-items:center;justify-content:space-between;
  padding:calc(var(--grid)*1.25) clamp(20px,4vw,40px);
  background:rgba(250,247,241,.9);backdrop-filter:blur(10px);border-bottom:1px solid var(--hairline);
}
.issue-topbar .mast{font-family:var(--display);font-weight:700;font-size:18px}
.issue-topbar .mast .the{font-style:italic;color:var(--issue-orange);font-size:.72em;vertical-align:.18em}
.to-cover{appearance:none;border:0;background:none;cursor:pointer;font-family:var(--body);font-weight:500;font-size:13px;color:var(--ink);display:inline-flex;align-items:center;gap:6px}
.to-cover .up{color:var(--issue-orange)}

.home{max-width:62rem;margin:0 auto;padding:clamp(32px,6vw,72px) clamp(20px,4vw,40px) 80px}
.issue-head{display:flex;gap:clamp(16px,3vw,32px);align-items:flex-start;border-bottom:3px double var(--hairline);padding-bottom:calc(var(--grid)*3);margin-bottom:calc(var(--grid)*4)}
.issue-thumb{flex:0 0 auto;width:clamp(96px,16vw,148px);aspect-ratio:1/1;object-fit:cover;border:1px solid var(--hairline);background:var(--cover-green)}
.issue-meta .kick{font-family:var(--body);font-weight:600;font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:var(--issue-green)}
.issue-meta h1{font-family:var(--display);font-weight:700;font-size:clamp(1.8rem,4vw,2.6rem);margin:.2em 0 .1em}
.issue-meta h1 .the{font-style:italic;color:var(--issue-orange);font-size:.6em;vertical-align:.2em}
.issue-meta .sub{color:var(--espresso);font-weight:300;font-size:14px}

.toc{list-style:none;padding:0;margin:0}
.toc li{padding:calc(var(--grid)*2) 0;border-bottom:1px solid var(--hairline)}
.toc a{text-decoration:none;display:block}
.toc .sec{font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--issue-green);font-weight:600}
.toc .ttl{font-family:var(--display-th);font-weight:600;font-size:clamp(1.15rem,2.4vw,1.5rem);line-height:1.3;margin-top:6px}
.toc .by{font-size:12px;color:var(--espresso);margin-top:4px}
.toc a:hover .ttl{color:var(--issue-orange)}

/* ===================== Mobile ===================== */
@media (max-width:760px){
  .cover-art{width:100%;height:58%;top:0;
    -webkit-mask-image:linear-gradient(to bottom,#000 60%,transparent 100%);
    mask-image:linear-gradient(to bottom,#000 60%,transparent 100%);
    -webkit-mask-composite:source-over;mask-composite:add;}
  .cover-inner{justify-content:flex-end;padding-bottom:calc(11.5% + 24px)}
  .cover-mast{position:absolute;top:clamp(24px,8vh,60px);left:clamp(24px,6vw,40px)}
  .cover-issueline{position:absolute;top:calc(clamp(24px,8vh,60px) + clamp(3rem,11vw,4rem));left:clamp(24px,6vw,40px)}
  .cover-mid{max-width:none}
  .cover-foot{flex-direction:column;align-items:flex-start;gap:16px}
  body.opened .cover{transform:rotateY(0);opacity:0}
}

/* ===================== Reduced motion ===================== */
@media (prefers-reduced-motion:reduce){
  .cover{transition:opacity .5s ease}
  body.opened .cover{transform:none;opacity:0}
  .cover-open .arw{animation:none}
}
</style>
</head>
<body>

<!-- ===== ใต้ปก: สารบัญ ===== -->
<header class="issue-topbar">
  <span class="mast">Seize <span class="the">the</span> Day</span>
  <button class="to-cover" type="button" onclick="document.body.classList.remove('opened')">
    <span class="up" aria-hidden="true">▲</span> ปกฉบับ
  </button>
</header>

<main class="home">
  {% for grp in collections.issues %}
  {% set gi = grp.items | coverOf %}
  <section class="issue-block" id="issue-{{ grp.issue }}">
    <div class="issue-head">
      {% if gi.data.cover.image %}
      <img class="issue-thumb" src="/assets/img/{{ gi.data.issue_dir }}/{{ gi.data.cover.image }}" alt="ปกฉบับที่ {{ grp.issue }}">
      {% endif %}
      <div class="issue-meta">
        <div class="kick">ฉบับที่ {{ grp.issue }}</div>
        <h1>{{ gi.data.cover.title or 'Seize the Day' }}</h1>
        <div class="sub">{{ gi.data.issue_label }}</div>
      </div>
    </div>
    <ul class="toc">
      {% for a in grp.items %}
      {% set dep = site.departments[a.data.department] %}
      <li><a href="{{ a.url }}">
        <span class="sec">{{ dep.en }}</span>
        <div class="ttl">{{ a.data.title | safe }}</div>
        {% if a.data.author %}<div class="by">โดย {{ a.data.author }}</div>{% endif %}
      </a></li>
      {% endfor %}
    </ul>
  </section>
  {% endfor %}
</main>

<!-- ===== ปกเต็มจอ (พลิกได้) ===== -->
<div class="cover-stage" id="coverStage">
  <div class="cover" id="cover" role="button" tabindex="0"
       aria-label="เปิดอ่านนิตยสาร Seize the Day ฉบับที่ {{ d.issue }} {{ d.issue_label }}">
    <img class="cover-art" src="/assets/img/{{ d.issue_dir }}/{{ cv.image }}" alt="ปก: {{ cv.title }}">
    <div class="cover-band" aria-hidden="true"></div>
    <div class="cover-inner">
      <div class="cover-top">
        <div class="cover-mast">Seize <span class="the">the</span> Day</div>
        <div class="cover-issueline">นิตยสารออนไลน์รายเดือน · ฉบับที่ {{ d.issue }} · {{ d.issue_label }}</div>
      </div>
      <div class="cover-mid">
        <div class="cover-eyebrow">{{ d.kicker or 'เรื่องเด่นประจำฉบับ' }}</div>
        <h2 class="cover-headline">{{ d.title | safe }}</h2>
        <p class="cover-blurb">{{ cv.blurb }}</p>
      </div>
      <div class="cover-foot">
        <div class="cover-barcode">
          <div class="barcode" aria-hidden="true"></div>
          <div class="cover-code">{{ d.issue_code }}</div>
        </div>
        <span class="cover-open">คลิกเพื่อเปิดอ่าน <span class="arw" aria-hidden="true">→</span></span>
      </div>
    </div>
  </div>
</div>

<script>
  (function(){
    var cover = document.getElementById('cover');
    function open(){ document.body.classList.add('opened'); }
    cover.addEventListener('click', open);
    cover.addEventListener('keydown', function(e){
      if(e.key === 'Enter' || e.key === ' '){ e.preventDefault(); open(); }
    });
  })();
</script>
</body>
</html>
