---
# หน้าแรก — แผนที่ความคิด (knowledge graph) + สารบัญตามหมวด
permalink: /index.html
eleventyExcludeFromCollections: true
---
<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ site.wordmark }} — {{ site.tagline }}</title>
<meta name="description" content="{{ site.intro }}">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Thai:wght@300;400;500;600;700&family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/assets/css/studio.css">

{# ── knowledge graph (Interest Map) เป็น structured data ── #}
<script type="application/ld+json">{{ interestGraph | dump | safe }}</script>
</head>
<body>
<div class="wrap">

  <header class="masthead">
    <div class="wordmark">noppadol<span class="dot">·</span>online</div>
    <nav>
      <a href="#graph">แผนที่ความคิด</a>
      <a href="#index">หมวด</a>
      <a href="#about">เกี่ยวกับ</a>
    </nav>
  </header>

  <section class="hero" id="graph">
    <h1>พื้นที่บันทึกความคิด<br>และความสนใจส่วนตัว</h1>
    <p>ที่นี่คือโต๊ะทำงานที่ความสนใจหลายอย่างมาบรรจบกัน<br>บันทึกไว้เพื่อค้นหาความเป็นไปได้ใหม่ๆ ในชีวิต</p>
  </section>

  <div class="graph-stage">
    <svg class="graph" viewBox="0 0 900 540" role="img"
         aria-label="แผนที่ความสนใจข้ามศาสตร์ เชื่อมโยงกาแฟ หนังเพลง หนังสือ ถ่ายภาพ งานไม้ เทคโนโลยี เกษตร และการใช้ชีวิต">
      <g id="edges"></g>
      <g id="nodes"></g>
    </svg>
    <p class="graph-hint">เลื่อนเมาส์ทับหมวดเพื่อดูเส้นเชื่อม</p>
  </div>

  <section class="index" id="index">
    <div class="index-head">
      <h2>หมวดความสนใจ</h2>
      <span>Topics</span>
    </div>
    <div class="cards" id="cards"></div>
  </section>

  <footer class="foot" id="about">
    <span class="note">บันทึกโดย {{ site.author.name }} · กรุงเทพฯ</span>
  </footer>

</div>

<script>
/* ---------- ข้อมูลจาก Eleventy (site.js + เนื้อหาจริง) ---------- */
const TOPICS = {{ site.topics | dump | safe }};
const EDGES  = {{ site.edges | dump | safe }};
const DEPTS  = {{ site.departments | dump | safe }};
const POSTS  = [
{%- for a in collections.articles %}
  { title: {{ a.data.title | dump | safe }}, url: {{ a.url | dump | safe }}, dept: {{ a.data.department | dump | safe }}, topic: {{ (a.data.topic or "") | dump | safe }} },
{%- endfor %}
];
const SELF = {x:450, y:285};

/* posts จัดกลุ่มตามหมวด (ผ่าน department -> topic) */
const DEPT_TOPIC = {};
Object.entries(DEPTS).forEach(([d,o])=>{DEPT_TOPIC[d]=o.topic});
const postsByTopic = {};
Object.keys(TOPICS).forEach(k=>postsByTopic[k]=[]);
POSTS.forEach(p=>{const t=(p.topic && postsByTopic[p.topic]) ? p.topic : DEPT_TOPIC[p.dept]; if(t&&postsByTopic[t])postsByTopic[t].push(p)});

/* ---------- adjacency ---------- */
const adj = {};
Object.keys(TOPICS).forEach(k=>adj[k]=new Set());
EDGES.forEach(([a,b])=>{adj[a].add(b);adj[b].add(a)});

const SVGNS="http://www.w3.org/2000/svg";
const gEdges=document.getElementById("edges");
const gNodes=document.getElementById("nodes");
const graph=document.querySelector(".graph");
const color=h=>`hsl(${h} 42% 52%)`;

/* ---------- เส้นเชื่อม ---------- */
const edgeEls={};
function addLine(x1,y1,x2,y2,cls,delay){
  const l=document.createElementNS(SVGNS,"line");
  l.setAttribute("x1",x1);l.setAttribute("y1",y1);
  l.setAttribute("x2",x2);l.setAttribute("y2",y2);
  l.setAttribute("class",cls);
  if(delay!=null)l.style.animationDelay=delay+"ms";
  gEdges.appendChild(l);return l;
}
Object.values(TOPICS).forEach((t,i)=>{
  const l=addLine(SELF.x,SELF.y,t.x,t.y,"edge",60+i*25);
  l.style.stroke="#CCD4E1";
});
EDGES.forEach(([a,b],i)=>{
  const A=TOPICS[a],B=TOPICS[b];
  const l=addLine(A.x,A.y,B.x,B.y,"edge",120+i*22);
  edgeEls[a+"|"+b]=l;edgeEls[b+"|"+a]=l;
});

/* ---------- nodes ---------- */
function addNode(key,t,delay){
  const g=document.createElementNS(SVGNS,"g");
  g.setAttribute("class","node");
  g.setAttribute("data-key",key);
  g.style.setProperty("--topic",color(t.hue));
  g.style.animationDelay=delay+"ms";
  const r=44;
  const halo=document.createElementNS(SVGNS,"circle");
  halo.setAttribute("class","halo");halo.setAttribute("cx",t.x);halo.setAttribute("cy",t.y);halo.setAttribute("r",r+8);
  const disc=document.createElementNS(SVGNS,"circle");
  disc.setAttribute("class","disc");disc.setAttribute("cx",t.x);disc.setAttribute("cy",t.y);disc.setAttribute("r",r);
  const lb=document.createElementNS(SVGNS,"text");
  lb.setAttribute("class","label");lb.setAttribute("x",t.x);lb.setAttribute("y",t.y+2);
  const parts=t.th.split(" · ");
  if(parts.length>1){
    lb.setAttribute("y",t.y-4);
    parts.forEach((p,idx)=>{
      const ts=document.createElementNS(SVGNS,"tspan");
      ts.setAttribute("x",t.x);ts.setAttribute("dy",idx===0?0:16);ts.textContent=p;
      lb.appendChild(ts);
    });
  }else{lb.textContent=t.th;}
  const en=document.createElementNS(SVGNS,"text");
  en.setAttribute("class","label-en");en.setAttribute("x",t.x);en.setAttribute("y",t.y+(parts.length>1?28:20));
  en.textContent=t.en;
  g.append(halo,disc,lb,en);
  gNodes.appendChild(g);
  return g;
}
const nodeEls={};
Object.entries(TOPICS).forEach(([k,t],i)=>{nodeEls[k]=addNode(k,t,180+i*30)});

const THINKER_SRC = "/assets/img/thinker.svg";
/* node กลาง (ตัวตน) = The Thinker (ลายเส้นขาวจากไฟล์ที่อัปโหลด) */
(function(){
  const g=document.createElementNS(SVGNS,"g");
  g.setAttribute("class","node self");
  g.setAttribute("aria-label","The Thinker");
  const disc=document.createElementNS(SVGNS,"circle");
  disc.setAttribute("class","disc");disc.setAttribute("cx",SELF.x);disc.setAttribute("cy",SELF.y);disc.setAttribute("r",42);
    const core=document.createElementNS(SVGNS,"g");
  core.setAttribute("class","self-core");
  const img=document.createElementNS(SVGNS,"image");
  img.setAttribute("class","thinker-img");
  const TW=35, TH=57;
  img.setAttribute("x",SELF.x-TW/2);img.setAttribute("y",SELF.y-TH/2);
  img.setAttribute("width",TW);img.setAttribute("height",TH);
  img.setAttribute("preserveAspectRatio","xMidYMid meet");
  img.setAttributeNS("http://www.w3.org/1999/xlink","xlink:href",THINKER_SRC);
  img.setAttribute("href",THINKER_SRC);
  const halo=document.createElementNS(SVGNS,"circle");
  halo.setAttribute("class","halo");halo.setAttribute("cx",SELF.x);halo.setAttribute("cy",SELF.y);halo.setAttribute("r",50);
  core.append(halo,disc,img);
  g.appendChild(core);gNodes.appendChild(g);
  // hover โหนดกลาง: เส้นทั้งกราฟเป็นน้ำเงิน + halo รอบวงกลม (เหมือนโหนดอื่น)
  g.setAttribute("tabindex","0");
  const selfOn=()=>graph.classList.add("self-focus");
  const selfOff=()=>graph.classList.remove("self-focus");
  g.addEventListener("mouseenter",selfOn);
  g.addEventListener("mouseleave",selfOff);
  g.addEventListener("focus",selfOn);
  g.addEventListener("blur",selfOff);
})();

/* ---------- interactivity ---------- */
function focusKey(key){
  graph.classList.add("focusing");
  const t=TOPICS[key];
  Object.keys(nodeEls).forEach(k=>{
    nodeEls[k].classList.remove("active","near");
    nodeEls[k].style.setProperty("--topic",color(t.hue));
  });
  nodeEls[key].classList.add("active");
  adj[key].forEach(n=>nodeEls[n].classList.add("near"));
  Object.values(edgeEls).forEach(l=>l.classList.remove("hot"));
  adj[key].forEach(n=>{
    const l=edgeEls[key+"|"+n];
    if(l){l.classList.add("hot");l.style.setProperty("--topic",color(t.hue));}
  });
}
function clearFocus(){
  graph.classList.remove("focusing");
  Object.values(nodeEls).forEach(n=>n.classList.remove("active","near"));
  Object.values(edgeEls).forEach(l=>l.classList.remove("hot"));
}
Object.entries(nodeEls).forEach(([k,el])=>{
  el.addEventListener("mouseenter",()=>focusKey(k));
  el.addEventListener("focus",()=>focusKey(k));
  el.setAttribute("tabindex","0");
});
gNodes.addEventListener("mouseleave",clearFocus);

/* ---------- topic index cards ---------- */
const cards=document.getElementById("cards");
Object.entries(TOPICS).forEach(([k,t])=>{
  const card=document.createElement("div");
  card.className="card";
  card.style.setProperty("--topic",color(t.hue));
  const ps=postsByTopic[k]||[];
  const n=ps.length;
  const items=n? ps.map(p=>`<li><a href="${p.url}">${p.title}</a></li>`).join("")
              : `<li class="soon">เร็ว ๆ นี้</li>`;
  card.innerHTML=`
    <div class="c-top">
      <div>
        <div class="c-th">${t.th}</div>
        <div class="c-en">${t.en}</div>
      </div>
      <div class="c-count ${n?'':'empty'}">${n? n+' บทความ':'—'}</div>
    </div>
    <p class="c-blurb">${t.blurb}</p>
    <ul>${items}</ul>`;
  card.addEventListener("mouseenter",()=>{nodeEls[k]&&nodeEls[k].dispatchEvent(new Event("mouseenter"))});
  card.addEventListener("mouseleave",clearFocus);
  cards.appendChild(card);
});
</script>
</body>
</html>
