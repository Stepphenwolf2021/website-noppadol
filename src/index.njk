---
permalink: /index.html
eleventyExcludeFromCollections: true
---
{% set pal = collections.issues[0].items[0].data.palette %}
<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ site.name }} — {{ site.tagline }}</title>
<meta name="description" content="{{ site.tagline }} — อ่านเป็นเรื่อง ๆ ตามหมวด สิ้นเดือนคัดมารวมเป็นเล่ม">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;0,800;1,400;1,600&family=Trirong:ital,wght@0,500;0,600;0,700;1,500;1,600&family=IBM+Plex+Sans+Thai:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/assets/css/seize.css">

<style>
:root{
  --issue-green:{{ pal.issue_green }};
  --issue-orange:{{ pal.issue_orange }};
  --issue-red:{{ pal.issue_red }};
}

.zine{max-width:64rem;margin:0 auto;padding:clamp(40px,7vw,88px) clamp(22px,5vw,48px) 96px}

/* ---- หัวเว็บ ---- */
.site-head{text-align:center;padding-bottom:calc(var(--grid)*4);border-bottom:3px double var(--hairline)}
.masthead{
  font-family:var(--display);font-weight:800;
  font-size:clamp(3rem,9vw,6rem);line-height:.96;letter-spacing:-.005em;margin:0;color:var(--ink);
}
.masthead .the{font-style:italic;color:var(--issue-orange);font-size:.52em;vertical-align:.22em;margin:0 .06em;font-weight:600}
.tagline{
  margin:calc(var(--grid)*2) auto 0;max-width:42ch;
  font-family:var(--body);font-weight:300;font-size:clamp(1rem,2vw,1.18rem);
  line-height:1.6;color:var(--espresso);
}

/* ---- โต๊ะ/หมวด ---- */
.desk{padding-top:calc(var(--grid)*5);margin-top:calc(var(--grid)*5);border-top:1px solid var(--hairline)}
.desk:first-of-type{border-top:0}
.desk-head{display:flex;align-items:baseline;gap:calc(var(--grid)*1.5);margin-bottom:calc(var(--grid)*3)}
.desk-en{font-family:var(--body);font-weight:600;font-size:13px;letter-spacing:.2em;text-transform:uppercase;color:var(--issue-green)}
.desk-th{font-family:var(--body);font-weight:400;font-size:13px;letter-spacing:.04em;color:var(--espresso)}

.desk-list{list-style:none;margin:0;padding:0;display:grid;gap:calc(var(--grid)*4)}
.desk-list a{text-decoration:none;display:block;color:inherit}
.entry .eyebrow{font-family:var(--body);font-weight:600;font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--issue-red);display:block;margin-bottom:6px}
.entry-title{
  font-family:var(--display-th);font-weight:700;
  font-size:clamp(1.45rem,3.2vw,2.1rem);line-height:1.2;margin:0;color:var(--ink);text-wrap:balance;
}
.desk-list a:hover .entry-title{color:var(--issue-orange)}
.entry-deck{
  margin:calc(var(--grid)*1.25) 0 0;max-width:54ch;
  font-family:var(--body);font-weight:300;font-size:clamp(1rem,1.6vw,1.1rem);line-height:1.6;color:var(--espresso);
}
.entry-meta{margin-top:calc(var(--grid)*1.5);font-family:var(--body);font-size:12px;letter-spacing:.06em;color:var(--espresso);opacity:.85}
.entry-meta .dot{color:var(--issue-orange);margin:0 .4em}

.desk-empty{font-family:var(--body);font-weight:300;font-style:italic;font-size:14px;color:var(--espresso);opacity:.6;margin:0}

/* ---- ท้ายเว็บ ---- */
.zine-foot{margin-top:calc(var(--grid)*10);padding-top:calc(var(--grid)*4);border-top:3px double var(--hairline);text-align:center}
.zine-foot .mast{font-family:var(--display);font-weight:700;font-size:18px;color:var(--ink)}
.zine-foot .mast .the{font-style:italic;color:var(--issue-orange);font-size:.72em;vertical-align:.18em}
.zine-foot .note{margin-top:6px;font-family:var(--body);font-size:12px;letter-spacing:.04em;color:var(--espresso)}

@media (max-width:560px){
  .desk-head{flex-direction:column;gap:2px}
}
</style>
</head>
<body>

<main class="zine">
  <header class="site-head">
    <h1 class="masthead">Seize <span class="the">the</span> Day</h1>
    <p class="tagline">นิตยสารออนไลน์ — อ่านเป็นเรื่อง ๆ ตามหมวด แล้วสิ้นเดือนเราคัดมารวมเป็น “เล่ม”</p>
  </header>

  {% for key, dept in site.departments %}
  {% set arts = collections.departments[key] %}
  <section class="desk" id="{{ key }}">
    <div class="desk-head">
      <span class="desk-en">{{ dept.en }}</span>
      <span class="desk-th">· {{ dept.th }}</span>
    </div>
    {% if arts and arts.length %}
    <ul class="desk-list">
      {% for a in arts %}
      <li class="entry"><a href="{{ a.url }}">
        {% if a.data.featured and a.data.kicker %}<span class="eyebrow">{{ a.data.kicker }}</span>{% endif %}
        <h2 class="entry-title">{{ a.data.title | safe }}</h2>
        {% if a.data.subtitle %}<p class="entry-deck">{{ a.data.subtitle }}</p>{% endif %}
        <div class="entry-meta">
          {% if a.data.author %}โดย {{ a.data.author }}{% endif %}
          {% if a.data.reading_time %}<span class="dot">·</span>อ่าน {{ a.data.reading_time }} นาที{% endif %}
        </div>
      </a></li>
      {% endfor %}
    </ul>
    {% else %}
    <p class="desk-empty">เร็ว ๆ นี้</p>
    {% endif %}
  </section>
  {% endfor %}

  <footer class="zine-foot">
    <div class="mast">Seize <span class="the">the</span> Day</div>
    <div class="note">{{ site.tagline }} · {{ collections.issues[0].items[0].data.issue_label }}</div>
  </footer>
</main>

</body>
</html>
