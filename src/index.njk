---
# หน้าแรกชั่วคราว (Back Issues / สารบัญ) — แทน cover flip จริงในภายหลัง
permalink: /index.html
eleventyExcludeFromCollections: true
---
<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ site.name }} — {{ site.tagline }}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,600&family=Trirong:wght@600;700&family=IBM+Plex+Sans+Thai:wght@300;400;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/assets/css/seize.css">
<style>
  .home{max-width:60rem;margin:0 auto;padding:calc(var(--grid)*8) calc(var(--grid)*3)}
  .home h1{font-family:var(--display);font-weight:700;font-size:clamp(2.4rem,7vw,4rem);margin:0}
  .home h1 .the{font-style:italic;color:var(--issue-orange);font-size:.6em;vertical-align:.2em}
  .home .tag{color:var(--espresso);margin:.4em 0 calc(var(--grid)*6)}
  .issue-block{border-top:3px double var(--hairline);padding-top:calc(var(--grid)*3);margin-top:calc(var(--grid)*5)}
  .issue-block h2{font-family:var(--display-th);font-weight:700;font-size:1.5rem;margin:0 0 calc(var(--grid)*2)}
  .toc{list-style:none;padding:0;margin:0}
  .toc li{padding:calc(var(--grid)*1.5) 0;border-bottom:1px solid var(--hairline)}
  .toc a{text-decoration:none;display:block}
  .toc .sec{font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--issue-green);font-weight:600}
  .toc .ttl{font-family:var(--display-th);font-weight:600;font-size:1.25rem;line-height:1.3;margin-top:4px}
  .toc a:hover .ttl{color:var(--issue-orange)}
</style>
</head>
<body>
  <main class="home">
    <h1>Seize <span class="the">the</span> Day</h1>
    <p class="tag">{{ site.tagline }}</p>

    {% for grp in collections.issues %}
    <section class="issue-block" id="issue-{{ grp.issue }}">
      <h2>ฉบับที่ {{ grp.issue }}{% if grp.items[0].data.issue_label %} · {{ grp.items[0].data.issue_label }}{% endif %}</h2>
      <ul class="toc">
        {% for a in grp.items %}
        {% set d = site.departments[a.data.department] %}
        <li><a href="{{ a.url }}">
          <span class="sec">{{ d.en }}</span>
          <div class="ttl">{{ a.data.title | safe }}</div>
        </a></li>
        {% endfor %}
      </ul>
    </section>
    {% endfor %}
  </main>
</body>
</html>
